{
  "name": "@bridgeai/shared",
  "version": "0.1.0",
  "private": true,
  "description": "BridgeAI 共享类型定义和工具函数",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types/visionShare": {
      "types": "./src/types/visionShare.ts"
    },
    "./types/dating": {
      "types": "./src/types/dating.ts"
    },
    "./types/disclosure": {
      "types": "./src/types/disclosure.ts"
    }
  },
  "scripts": {
    "build": "tsc --declaration --emitDeclarationOnly -p tsconfig.json && tsup src/index.ts --format cjs,esm",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
