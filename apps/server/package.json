{
  "name": "@bridgeai/server",
  "version": "0.1.0",
  "private": true,
  "description": "BridgeAI 后端服务 - Express + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathIgnorePatterns='integration'",
    "clean": "rm -rf dist",
    "db:migrate": "prisma migrate dev",
    "db:migrate:dev": "dotenv -e .env.development -- prisma migrate dev",
    "db:migrate:test": "dotenv -e .env.test -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:status:dev": "dotenv -e .env.development -- prisma migrate status",
    "db:migrate:status:test": "dotenv -e .env.test -- prisma migrate status",
    "db:migrate:status:prod": "dotenv -e .env.production -- prisma migrate status",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:migrate:rollback": "prisma migrate resolve --rolled-back",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx scripts/seed-demo.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "test:integration": "jest --testPathPattern='integration' --runInBand",
    "migration:create": "tsx scripts/migration-workflow.ts create",
    "migration:review": "tsx scripts/migration-workflow.ts review",
    "migration:approve": "tsx scripts/migration-workflow.ts approve",
    "migration:reject": "tsx scripts/migration-workflow.ts reject",
    "migration:execute": "tsx scripts/migration-workflow.ts execute",
    "migration:diff": "tsx scripts/migration-workflow.ts diff",
    "migration:backup": "tsx scripts/migration-workflow.ts backup",
    "migration:deploy:safe": "tsx scripts/migration-workflow.ts deploy:safe",
    "migration:detect-destructive": "tsx scripts/migration-workflow.ts detect-destructive",
    "migration:rollback": "tsx scripts/migration-workflow.ts rollback",
    "migration:restore": "tsx scripts/migration-workflow.ts restore",
    "migration:audit-log": "tsx scripts/migration-workflow.ts audit-log",
    "docs:generate": "tsx scripts/generate-api-docs.ts",
    "docs:generate:watch": "tsx scripts/generate-api-docs.ts --watch"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@bridgeai/shared": "workspace:*",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^7.100.0",
    "@sentry/profiling-node": "^7.100.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.75.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^10.3.1",
    "prisma": "^5.10.0",
    "rate-limit-redis": "^4.2.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "dotenv-cli": "^7.3.0",
    "esbuild": "0.19.12",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
