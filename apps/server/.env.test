# Test Environment Configuration
NODE_ENV=test
PORT=3002
HOST=localhost
CORS_ORIGIN=*
LOG_LEVEL=silent
REQUEST_TIMEOUT_MS=30000

# Test Database (isolated from dev/prod)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/visionshare_test

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-do-not-use-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# Test-specific settings
TEST_TIMEOUT=30000
