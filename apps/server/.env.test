# Test Environment Configuration
NODE_ENV=test
PORT=3002
HOST=localhost
API_URL=http://localhost:3002
CLIENT_URL=http://localhost:8081
CORS_ORIGIN=*
LOG_LEVEL=debug
REQUEST_TIMEOUT_MS=30000

# Test Database (isolated from dev/prod)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bridgeai_test
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bridgeai_test
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-do-not-use-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=dev-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# AI Service Configuration (local LLM proxy from ~/.claude/settings.json)
ANTHROPIC_API_KEY=sk-proxy-local-llm-router
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_MODEL=glm-5.1

# Object Storage (S3/MinIO)
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=bridgeai-test
S3_PUBLIC_URL=http://localhost:9000/bridgeai-test

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security Configuration
BCRYPT_ROUNDS=10

# Test-specific settings
TEST_TIMEOUT=30000
