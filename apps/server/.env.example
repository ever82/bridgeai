# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/visionshare

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Request Timeout
REQUEST_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=debug

# API
API_VERSION=v1
API_PREFIX=/api
