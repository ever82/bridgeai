// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户相关
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  passwordHash  String    @map("password_hash")
  name          String?
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  bio           String?
  website       String?
  location      String?
  phone         String?    /// @encrypted - PII field
  phoneVerified Boolean   @default(false) @map("phone_verified")
  status        UserStatus @default(ACTIVE)
  privacySettings Json?   @map("privacy_settings") // Profile visibility, online status, etc.
  lastLoginAt   DateTime? @map("last_login_at")
  loginAttempts Int       @default(0) @map("login_attempts")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  agents        Agent[]
  sentMessages  Message[] @relation("SentMessages")
  ratingsGiven  Rating[]  @relation("Rater")
  ratingsReceived Rating[] @relation("Ratee")
  creditRecords CreditRecord[]
  creditScore   CreditScore?
  transactions  Transaction[]
  connections   Connection[]
  devices       UserDevice[]
  blockedUsers  BlockedUser[] @relation("BlockingUser")
  blockedBy     BlockedUser[] @relation("BlockedByUser")
  roles         UserRole[]  // RBAC roles
  pointsAccount PointsAccount?
  visionShareTasks VisionShareTask[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Agent 相关
// ============================================

model Agent {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  type        AgentType
  name        String
  description String?
  status      AgentStatus @default(DRAFT)
  config      Json?
  latitude    Float?
  longitude   Float?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  demands     Demand[]
  supplies    Supply[]
  profiles    AgentProfile[]

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([latitude, longitude])
  @@map("agents")
}

enum AgentType {
  VISIONSHARE @map("visionshare")
  AGENTDATE   @map("agentdate")
  AGENTJOB    @map("agentjob")
  AGENTAD     @map("agentad")
}

enum AgentStatus {
  DRAFT     @map("draft")
  ACTIVE    @map("active")
  PAUSED    @map("paused")
  ARCHIVED  @map("archived")
}

// ============================================
// 需求相关
// ============================================

model Demand {
  id          String       @id @default(uuid())
  agentId     String       @map("agent_id")
  title       String
  description String?
  tags        String[]
  budgetMin   Decimal?     @map("budget_min") @db.Decimal(10, 2)
  budgetMax   Decimal?     @map("budget_max") @db.Decimal(10, 2)
  latitude    Float?
  longitude   Float?
  status      DemandStatus @default(OPEN)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  matches     Match[]

  @@index([agentId])
  @@index([status])
  @@index([tags])
  @@map("demands")
}

enum DemandStatus {
  OPEN
  MATCHED
  CLOSED
}

// ============================================
// 供给相关
// ============================================

model Supply {
  id          String        @id @default(uuid())
  agentId     String        @map("agent_id")
  title       String
  description String?
  skills      String[]
  hourlyRate  Decimal?      @map("hourly_rate") @db.Decimal(10, 2)
  latitude    Float?
  longitude   Float?
  availability Json?
  status      SupplyStatus  @default(AVAILABLE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  agent       Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  matches     Match[]

  @@index([agentId])
  @@index([status])
  @@index([skills])
  @@map("supplies")
}

enum SupplyStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

// ============================================
// 匹配相关
// ============================================

model Match {
  id          String      @id @default(uuid())
  demandId    String      @map("demand_id")
  supplyId    String      @map("supply_id")
  score       Decimal     @db.Decimal(5, 2)
  status      MatchStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  demand      Demand      @relation(fields: [demandId], references: [id], onDelete: Cascade)
  supply      Supply      @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  conversation Conversation?
  ratings     Rating[]

  @@unique([demandId, supplyId])
  @@index([demandId])
  @@index([supplyId])
  @@index([status])
  @@map("matches")
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

// ============================================
// 会话和消息
// ============================================

model Conversation {
  id            String    @id @default(uuid())
  matchId       String    @unique @map("match_id")
  participantIds String[]  @map("participant_ids")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([matchId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String        @id @default(uuid())
  conversationId  String        @map("conversation_id")
  senderId        String        @map("sender_id")
  content         String    /// @encrypted - Message content encryption
  type            MessageType   @default(TEXT)
  attachments     Json?
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User          @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

// ============================================
// 评分相关
// ============================================

model Rating {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  raterId   String   @map("rater_id")
  rateeId   String   @map("ratee_id")
  score     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  rater     User     @relation("Rater", fields: [raterId], references: [id])
  ratee     User     @relation("Ratee", fields: [rateeId], references: [id])

  @@index([matchId])
  @@index([rateeId])
  @@map("ratings")
}

// ============================================
// 场景相关
// ============================================

model Scene {
  id          String     @id @default(uuid())
  code        SceneCode  @unique
  name        String
  description String?
  icon        String?
  color       String?
  isActive    Boolean    @default(true) @map("is_active")
  config      Json?      // 场景专属配置
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  agentProfiles AgentProfile[]
  chatRooms     ChatRoom[]

  @@map("scenes")
}

enum SceneCode {
  VISION_SHARE  @map("vision_share")
  AGENT_DATE    @map("agent_date")
  AGENT_JOB     @map("agent_job")
  AGENT_AD      @map("agent_ad")
}

// ============================================
// Agent 画像相关
// ============================================

model AgentProfile {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  sceneId   String   @map("scene_id")

  // L1 - 基础信息（系统可查询）
  l1Data    Json     @map("l1_data")  // location, timeRange, category, budget

  // L2 - 结构化信息（Agent可读的自然语言）
  l2Data    Json     @map("l2_data")  // description, requirements, capabilities

  // L3 - 自然语言描述（完整描述）
  l3Text            String?   @map("l3_text") @db.Text  // 原始文本
  l3Description     String?   @map("l3_description")    // AI提炼后的描述
  l3ExtractionData  Json?     @map("l3_extraction_data") // 从L3提取的L2数据
  l3ExtractionConfidence Float? @map("l3_extraction_confidence") // 提炼置信度

  // 提炼历史
  extractionHistory Json?     @map("extraction_history") // 提炼历史记录

  // 场景专属配置
  sceneConfig   Json?    @map("scene_config")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scene     Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([agentId, sceneId])
  @@index([agentId])
  @@index([sceneId])
  @@index([l3ExtractionConfidence])
  @@map("agent_profiles")
}

// ============================================
// 聊天室相关（四人群聊）
// ============================================

model ChatRoom {
  id            String        @id @default(uuid())
  sceneId       String?       @map("scene_id")
  matchId       String?       @unique @map("match_id")
  type          ChatRoomType  @default(QUAD)
  status        ChatRoomStatus @default(ACTIVE)
  participantIds String[]     @map("participant_ids")  // 存储 userIds
  metadata      Json?
  lastMessageAt DateTime?     @map("last_message_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  scene         Scene?        @relation(fields: [sceneId], references: [id])
  messages      ChatMessage[]
  connections   Connection[]

  @@index([sceneId])
  @@index([matchId])
  @@index([lastMessageAt])
  @@index([status])
  @@map("chat_rooms")
}

enum ChatRoomType {
  QUAD       @map("quad")       // 四人群聊（默认）
  PRIVATE    @map("private")    // 私聊
  GROUP      @map("group")      // 多人群聊
}

enum ChatRoomStatus {
  ACTIVE     @map("active")
  INACTIVE   @map("inactive")
  CLOSED     @map("closed")
}

model ChatMessage {
  id           String       @id @default(uuid())
  chatRoomId   String       @map("chat_room_id")
  senderId     String       @map("sender_id")
  senderType   SenderType   @map("sender_type")  // USER 或 AGENT
  content      String    /// @encrypted - Chat message content encryption
  type         MessageType  @default(TEXT)
  attachments  Json?
  metadata     Json?        // 包含私聊建议标记等
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  chatRoom     ChatRoom     @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

enum SenderType {
  USER   @map("user")
  AGENT  @map("agent")
}

// ============================================
// 连接管理（Socket/WebSocket）
// ============================================

model Connection {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  chatRoomId String?          @map("chat_room_id")
  socketId   String           @unique @map("socket_id")
  deviceInfo Json?            @map("device_info")
  ipAddress  String?          @map("ip_address")
  status     ConnectionStatus @default(ONLINE)
  lastPingAt DateTime?        @map("last_ping_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  // Relations
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatRoom   ChatRoom?        @relation(fields: [chatRoomId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([chatRoomId])
  @@index([status])
  @@index([lastPingAt])
  @@map("connections")
}

enum ConnectionStatus {
  ONLINE      @map("online")
  AWAY        @map("away")
  BUSY        @map("busy")
  OFFLINE     @map("offline")
}

// ============================================
// 信用和积分相关
// ============================================

model CreditRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  score       Int      // 当前信用分
  delta       Int      // 变化值
  reason      String   // 变化原因
  sourceType  String   @map("source_type")  // RATING, TRANSACTION, COMPLAINT 等
  sourceId    String?  @map("source_id")    // 关联记录ID
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_records")
}

// 信用分主表 - 存储用户当前信用分
model CreditScore {
  id            String      @id @default(uuid())
  userId        String      @unique @map("user_id")
  score         Int         @default(600)  // 当前信用分 (0-1000)
  level         CreditLevel @default(GENERAL) // 信用等级
  lastUpdatedAt DateTime    @default(now()) @map("last_updated_at")
  updateCount   Int         @default(0) @map("update_count") // 更新次数(防刷分)
  nextUpdateAt  DateTime?   @map("next_update_at") // 下次可更新时间
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  histories     CreditHistory[]
  factors       CreditFactor[]

  @@index([userId])
  @@index([score])
  @@index([level])
  @@map("credit_scores")
}

// 信用分历史记录
model CreditHistory {
  id          String   @id @default(uuid())
  creditId    String   @map("credit_id")
  oldScore    Int      @map("old_score")
  newScore    Int      @map("new_score")
  delta       Int      // 变化值
  reason      String   // 变化原因
  sourceType  String   @map("source_type") // PROFILE_UPDATE, TRANSACTION, RATING, SCHEDULED 等
  sourceId    String?  @map("source_id")   // 关联记录ID
  metadata    Json?    // 额外信息
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  creditScore CreditScore @relation(fields: [creditId], references: [id], onDelete: Cascade)

  @@index([creditId])
  @@index([createdAt])
  @@map("credit_histories")
}

// 信用分维度评分
model CreditFactor {
  id            String   @id @default(uuid())
  creditId      String   @map("credit_id")
  factorType    String   @map("factor_type") // PROFILE, BEHAVIOR, TRANSACTION, SOCIAL
  subFactor     String   @map("sub_factor")  // 子维度，如 profile_completeness
  score         Int      // 该维度得分 (0-100)
  weight        Float    // 权重
  calculatedAt  DateTime @default(now()) @map("calculated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  creditScore   CreditScore @relation(fields: [creditId], references: [id], onDelete: Cascade)

  @@unique([creditId, factorType, subFactor])
  @@index([creditId])
  @@index([factorType])
  @@map("credit_factors")
}

enum CreditLevel {
  EXCELLENT @map("excellent") // 优秀 900-1000
  GOOD      @map("good")      // 良好 750-899
  GENERAL   @map("general")   // 一般 600-749
  POOR      @map("poor")      // 较差 <600
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  description String?
  referenceId String?         @map("reference_id")  // 关联订单/匹配ID
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

enum TransactionType {
  RECHARGE    @map("recharge")     // 充值
  REWARD      @map("reward")       // 奖励
  DEDUCT      @map("deduct")       // 扣除
  REFUND      @map("refund")       // 退款
  TRANSFER    @map("transfer")     // 转账
}

enum TransactionStatus {
  PENDING     @map("pending")
  SUCCESS     @map("success")
  FAILED      @map("failed")
  CANCELLED   @map("cancelled")
}

// ============================================
// 积分系统相关 (Points System)
// ============================================

// 积分账户 - 每个用户有一个积分账户
model PointsAccount {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  balance       Int      @default(0) // 当前可用余额
  totalEarned   Int      @default(0) @map("total_earned") // 总获取积分
  totalSpent    Int      @default(0) @map("total_spent") // 总消耗积分
  frozenAmount  Int      @default(0) @map("frozen_amount") // 冻结金额（交易担保）
  version       Int      @default(0) // 乐观锁版本号
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  PointsTransaction[]
  freezeRecords PointsFreeze[]

  @@index([userId])
  @@index([balance])
  @@map("points_accounts")
}

// 积分交易记录
model PointsTransaction {
  id          String              @id @default(uuid())
  accountId   String              @map("account_id")
  userId      String              @map("user_id")
  type        PointsTransactionType // 交易类型
  amount      Int                 // 交易金额（正数为收入，负数为支出）
  balanceAfter Int                @map("balance_after") // 交易后余额
  description String?             // 交易描述
  scene       SceneCode?          // 关联场景
  referenceId String?             @map("reference_id") // 关联记录ID（如订单ID）
  metadata    Json?               // 额外元数据
  createdAt   DateTime            @default(now()) @map("created_at")

  // Relations
  account     PointsAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  freezeRecord PointsFreeze?      // 可选关联的冻结记录

  @@index([accountId])
  @@index([userId])
  @@index([type])
  @@index([scene])
  @@index([createdAt])
  @@map("points_transactions")
}

// 积分冻结记录（用于交易担保）
model PointsFreeze {
  id            String          @id @default(uuid())
  accountId     String          @map("account_id")
  transactionId String?         @unique @map("transaction_id") // 关联的交易记录
  amount        Int             // 冻结金额
  reason        String          // 冻结原因/用途
  scene         SceneCode?      // 关联场景
  referenceId   String?         @map("reference_id") // 关联业务记录ID
  status        FreezeStatus    @default(FROZEN) // 冻结状态
  expiresAt     DateTime?       @map("expires_at") // 过期时间（自动解冻）
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  account       PointsAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction   PointsTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([status])
  @@index([expiresAt])
  @@index([referenceId])
  @@map("points_freezes")
}

enum PointsTransactionType {
  EARN        @map("earn")        // 获取积分（任务奖励、注册奖励等）
  SPEND       @map("spend")       // 消耗积分（查看照片等）
  RECHARGE    @map("recharge")    // 充值
  REFUND      @map("refund")      // 退款
  FROZEN      @map("frozen")      // 冻结
  UNFROZEN    @map("unfrozen")    // 解冻
  DEDUCT      @map("deduct")      // 扣除（惩罚）
  TRANSFER_IN @map("transfer_in")  // 转入
  TRANSFER_OUT @map("transfer_out") // 转出
}

enum FreezeStatus {
  FROZEN      @map("frozen")      // 冻结中
  USED        @map("used")         // 已使用（完成交易）
  RELEASED    @map("released")     // 已释放（取消交易）
  EXPIRED     @map("expired")      // 已过期
}

// ============================================
// 用户设备管理
// ============================================

model UserDevice {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  deviceId    String    @unique @map("device_id")
  deviceName  String?   @map("device_name")
  deviceType  String?   @map("device_type") // ios, android, web
  osVersion   String?   @map("os_version")
  appVersion  String?   @map("app_version")
  pushToken   String?   @map("push_token")
  ipAddress   String?   @map("ip_address")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  isCurrent   Boolean  @default(false) @map("is_current")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@map("user_devices")
}

// ============================================
// 阻止列表
// ============================================

model BlockedUser {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  blockedUserId String @map("blocked_user_id")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation("BlockingUser", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser User     @relation("BlockedByUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([userId])
  @@index([blockedUserId])
  @@map("blocked_users")
}

// ============================================
// RBAC 权限系统
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique  // user, admin, moderator
  displayName String   @map("display_name")  // 显示名称
  description String?  // 角色描述
  level       Int      @default(0)  // 角色层级，用于继承
  isSystem    Boolean  @default(false) @map("is_system")  // 系统角色不可删除
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  permissions RolePermission[]
  users       UserRole[]

  @@index([name])
  @@index([level])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String   // 资源，如 users, agents, posts
  action      String   // 操作，如 read, write, delete, admin
  name        String   @unique  // users:read, users:write
  description String?  // 权限描述
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  roles       RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@index([action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  grantedBy String?  @map("granted_by")  // 谁授予的角色
  expiresAt DateTime? @map("expires_at")  // 角色过期时间（可选）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================
// 保存的筛选器
// ============================================

model SavedFilter {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String   // 筛选器名称
  description String?  // 筛选器描述
  category    String?  // 分类
  filter      Json     // FilterDSL JSON
  isPublic    Boolean  @default(false) @map("is_public")  // 是否公开
  usageCount  Int      @default(0) @map("usage_count")     // 使用次数
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([isPublic, usageCount])
  @@map("saved_filters")
}

// ============================================
// 场景模板
// ============================================

model SceneTemplate {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")  // null for preset templates
  sceneId     String   @map("scene_id") // visionshare, agentdate, agentjob, agentad
  name        String   // 模板名称
  description String?  // 模板描述
  isPreset    Boolean  @default(false) @map("is_preset")  // 是否是预设模板
  isDefault   Boolean  @default(false) @map("is_default") // 是否用户默认模板
  fieldValues Json     // 字段默认值
  isPublic    Boolean  @default(false) @map("is_public")  // 是否公开
  usageCount  Int      @default(0) @map("usage_count")    // 使用次数
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sceneId])
  @@index([isPublic, usageCount])
  @@index([userId, sceneId, isDefault])
  @@map("scene_templates")
}

// ============================================
// VisionShare 任务发布
// ============================================

model VisionShareTask {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  agentId         String?             @map("agent_id")  // 关联的Agent
  title           String              // 任务标题
  description     String?             @db.Text          // 详细描述
  aiRefinedDescription String?        @map("ai_refined_description") @db.Text // AI提炼后的描述
  qualityScore    Float?              @map("quality_score") // 需求质量评分 (0-100)

  // 预算信息
  budgetType      BudgetType          @map("budget_type") // POINTS, CASH
  budgetAmount    Decimal             @map("budget_amount") @db.Decimal(10, 2)
  budgetCurrency  String?             @map("budget_currency") // CNY, USD等

  // 地理位置
  latitude        Float?
  longitude       Float?
  locationName    String?             @map("location_name")
  locationAddress String?             @map("location_address")

  // 时间窗口
  startTime       DateTime?           @map("start_time")
  endTime         DateTime?           @map("end_time")
  timeType        TimeType            @map("time_type") // IMMEDIATE, SCHEDULED

  // 有效期
  validHours      Int                 @default(24) @map("valid_hours") // 任务有效期(小时)
  expiresAt       DateTime            @map("expires_at")

  // 分类和标签
  category        String?             // 需求分类
  tags            String[]            // 标签数组
  aiGeneratedTags String[]            @map("ai_generated_tags") // AI生成的标签

  // 状态机
  status          VisionShareTaskStatus @default(DRAFT) @map("status")

  // 验证状态
  creditChecked   Boolean             @default(false) @map("credit_checked")
  creditScore     Int?                @map("credit_score") // 发布时的信用分
  contentFiltered Boolean             @default(false) @map("content_filtered")
  filterResult    Json?               @map("filter_result") // 过滤结果

  // 统计信息
  viewCount       Int                 @default(0) @map("view_count")
  matchCount      Int                 @default(0) @map("match_count")
  shareCount      Int                 @default(0) @map("share_count")

  // 发布控制
  publishCount    Int                 @default(0) @map("publish_count") // 当日发布计数
  dailyLimitHit   Boolean             @default(false) @map("daily_limit_hit")

  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  publishedAt     DateTime?           @map("published_at")
  completedAt     DateTime?           @map("completed_at")
  cancelledAt     DateTime?           @map("cancelled_at")

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  history         VisionShareTaskHistory[]

  @@index([userId])
  @@index([status])
  @@index([latitude, longitude])
  @@index([tags])
  @@index([category])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([userId, status])
  @@map("visionshare_tasks")
}

enum VisionShareTaskStatus {
  DRAFT       @map("draft")       // 草稿
  PUBLISHING  @map("publishing")  // 发布中
  PUBLISHED   @map("published")   // 已发布
  MATCHING    @map("matching")    // 匹配中
  IN_PROGRESS @map("in_progress") // 进行中
  COMPLETED   @map("completed")   // 已完成
  CANCELLED   @map("cancelled")   // 已取消
  EXPIRED     @map("expired")     // 已过期
}

enum BudgetType {
  POINTS  @map("points")
  CASH    @map("cash")
}

enum TimeType {
  IMMEDIATE   @map("immediate")
  SCHEDULED   @map("scheduled")
}

// VisionShare任务历史记录
model VisionShareTaskHistory {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  status      VisionShareTaskStatus @map("status")
  metadata    Json?    // 状态变更元数据
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  task        VisionShareTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
  @@map("visionshare_task_histories")
}
