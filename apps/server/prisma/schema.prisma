// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户相关
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  bio           String?   @db.Text
  website       String?
  location      String?
  phone         String?
  emailVerified Boolean   @default(false) @map("email_verified")
  phoneVerified Boolean   @default(false) @map("phone_verified")
  privacySettings Json?   @map("privacy_settings")
  status                UserStatus @default(ACTIVE)
  failedLoginAttempts   Int        @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime? @map("locked_until")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  agents        Agent[]
  sentMessages  Message[] @relation("SentMessages")
  ratingsGiven  Rating[]  @relation("Rater")
  ratingsReceived Rating[] @relation("Ratee")
  creditRecords CreditRecord[]
  transactions  Transaction[]
  connections   Connection[]
  devices       UserDevice[]
  blockedUsers  BlockedUser[] @relation("BlockingUser")
  blockedBy     BlockedUser[] @relation("BlockedByUser")
  roles         UserRole[]  // RBAC roles
  pointsAccount PointsAccount?
  notifications Notification[]
  notificationPrefs NotificationPreference?
  pushTokens    PushToken[]
  savedFilters  SavedFilter[]
  sceneTemplates SceneTemplate[]
  // Review relations
  reviewsGiven  Review[]    @relation("ReviewReviewer")
  reviewsReceived Review[]  @relation("ReviewReviewee")
  reviewReplies  ReviewReply[] @relation("ReviewReplyAuthor")
  reviewStats    ReviewStats[] @relation("ReviewStatsUser")
  refreshTokens  RefreshToken[]
  creditHistories CreditHistory[]
  creditScores   CreditScore[]
  roomParticipants RoomParticipant[]
  oauthConnections OAuthConnection[]
  visionShareTasks VisionShareTask[]
  couponTransactions CouponTransaction[]
  couponRatings   CouponRating[]
  offlineMessages  OfflineMessage[]
  readReceipts     ReadReceipt[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Agent 相关
// ============================================

model Agent {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  type        AgentType
  name        String
  description String?     @map("description") @db.Text
  status      AgentStatus @default(DRAFT)
  config      Json?
  latitude    Float?
  longitude   Float?
  isActive    Boolean     @default(true) @map("is_active")
  creditScore Int         @default(75) @map("credit_score")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  demands     Demand[]
  supplies    Supply[]
  profiles    AgentProfile[]
  merchant    Merchant?
  statusHistory AgentStatusHistory[]

  @@index([userId])
  @@index([type])
  @@index([latitude, longitude])
  @@map("agents")
}

model AgentStatusHistory {
  id        String      @id @default(uuid())
  agentId   String      @map("agent_id")
  status    AgentStatus
  reason    String?
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  agent     Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@map("agent_status_history")
}

enum AgentType {
  DEMAND
  SUPPLY
  VISIONSHARE
  AGENTDATE
  AGENTJOB
  AGENTAD
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// ============================================
// 需求相关
// ============================================

model Demand {
  id          String       @id @default(uuid())
  agentId     String       @map("agent_id")
  title       String
  description String?
  tags        String[]
  budgetMin   Decimal?     @map("budget_min") @db.Decimal(10, 2)
  budgetMax   Decimal?     @map("budget_max") @db.Decimal(10, 2)
  latitude    Float?
  longitude   Float?
  status      DemandStatus @default(OPEN)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  matches     Match[]

  @@index([agentId])
  @@index([status])
  @@index([tags])
  @@map("demands")
}

enum DemandStatus {
  OPEN
  MATCHED
  CLOSED
}

// ============================================
// 供给相关
// ============================================

model Supply {
  id          String        @id @default(uuid())
  agentId     String        @map("agent_id")
  title       String
  description String?
  skills      String[]
  hourlyRate  Decimal?      @map("hourly_rate") @db.Decimal(10, 2)
  latitude    Float?
  longitude   Float?
  availability Json?
  status      SupplyStatus  @default(AVAILABLE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  agent       Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  matches     Match[]

  @@index([agentId])
  @@index([status])
  @@index([skills])
  @@map("supplies")
}

enum SupplyStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

// ============================================
// 匹配相关
// ============================================

model Match {
  id          String      @id @default(uuid())
  demandId    String      @map("demand_id")
  supplyId    String      @map("supply_id")
  score       Decimal     @db.Decimal(5, 2)
  status      MatchStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  demand      Demand      @relation(fields: [demandId], references: [id], onDelete: Cascade)
  supply      Supply      @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  conversation Conversation?
  ratings     Rating[]

  @@unique([demandId, supplyId])
  @@index([demandId])
  @@index([supplyId])
  @@index([status])
  @@map("matches")
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

// ============================================
// 会话和消息
// ============================================

model Conversation {
  id            String    @id @default(uuid())
  matchId       String    @unique @map("match_id")
  participantIds String[]  @map("participant_ids")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([matchId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String        @id @default(uuid())
  conversationId  String        @map("conversation_id")
  senderId        String        @map("sender_id")
  content         String
  type            MessageType   @default(TEXT)
  status          MessageStatus @default(SENT)
  attachments     Json?
  sequenceId      Int?          @default(autoincrement()) @map("sequence_id")
  metadata        Json?
  editedAt        DateTime?     @map("edited_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User          @relation("SentMessages", fields: [senderId], references: [id])
  readReceipts    ReadReceipt[]

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// Read Receipt for messages
model ReadReceipt {
  id           String   @id @default(uuid())
  messageId    String   @map("message_id")
  userId       String   @map("user_id")
  readAt       DateTime @default(now()) @map("read_at")

  // Relations
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("read_receipts")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

// ============================================
// 评分相关
// ============================================

model Rating {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  raterId   String   @map("rater_id")
  rateeId   String   @map("ratee_id")
  score     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  rater     User     @relation("Rater", fields: [raterId], references: [id])
  ratee     User     @relation("Ratee", fields: [rateeId], references: [id])

  @@index([matchId])
  @@index([rateeId])
  @@map("ratings")
}

// ============================================
// 评价系统 (Review & Rating)
// ============================================

enum ReviewSceneType {
  VISION_SHARE  @map("vision_share")
  AGENT_DATE    @map("agent_date")
  AGENT_JOB     @map("agent_job")
  AGENT_AD      @map("agent_ad")
}

enum ReviewStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  HIDDEN    @map("hidden")
  DELETED   @map("deleted")
}

enum ModerationStatus {
  PENDING @map("pending")
  PASSED  @map("passed")
  FLAGGED @map("flagged")
  BLOCKED @map("blocked")
}

model Review {
  id               String           @id @default(uuid())
  matchId          String           @map("match_id")
  reviewerId       String           @map("reviewer_id")
  revieweeId       String           @map("reviewee_id")
  sceneType        ReviewSceneType? @map("scene_type")
  rating           Int              // 1-5
  title            String?
  content          String
  tags             String[]         @default([])
  status           ReviewStatus     @default(PENDING)
  moderationStatus ModerationStatus @default(PENDING)
  isVerified       Boolean          @default(false) @map("is_verified")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // Relations
  reviewer         User             @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  reviewee         User             @relation("ReviewReviewee", fields: [revieweeId], references: [id])
  replies          ReviewReply[]
  reports          ReviewReport[]
  moderationLogs   ReviewModerationLog[]

  @@index([matchId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([sceneType])
  @@index([status])
  @@index([moderationStatus])
  @@map("reviews")
}

model ReviewReply {
  id         String   @id @default(uuid())
  reviewId   String   @map("review_id")
  authorId   String   @map("author_id")
  content    String
  isOfficial Boolean  @default(false) @map("is_official")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author     User     @relation("ReviewReplyAuthor", fields: [authorId], references: [id])

  @@index([reviewId])
  @@index([authorId])
  @@map("review_replies")
}

enum ReportReason {
  SPAM          @map("spam")
  INAPPROPRIATE @map("inappropriate")
  FALSE         @map("false")
  HARASSMENT    @map("harassment")
  OTHER         @map("other")
}

enum ReportStatus {
  PENDING   @map("pending")
  RESOLVED  @map("resolved")
  DISMISSED @map("dismissed")
}

model ReviewReport {
  id          String       @id @default(uuid())
  reviewId    String       @map("review_id")
  reporterId  String       @map("reporter_id")
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  handledBy   String?      @map("handled_by")
  handledAt   DateTime?    @map("handled_at")
  resolution  String?
  createdAt   DateTime     @default(now()) @map("created_at")

  // Relations
  review      Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([reporterId])
  @@index([status])
  @@map("review_reports")
}

model ReviewStats {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  totalReviews   Int      @default(0) @map("total_reviews")
  avgRating      Float    @default(0) @map("avg_rating")
  fiveStarCount  Int      @default(0) @map("five_star_count")
  fourStarCount  Int      @default(0) @map("four_star_count")
  threeStarCount Int      @default(0) @map("three_star_count")
  twoStarCount   Int      @default(0) @map("two_star_count")
  oneStarCount   Int      @default(0) @map("one_star_count")
  responseRate   Float    @default(0) @map("response_rate")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user           User     @relation("ReviewStatsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("review_stats")
}

model ReviewModerationLog {
  id          String   @id @default(uuid())
  reviewId    String   @map("review_id")
  action      String   // APPROVED, BLOCKED, FLAGGED, HIDDEN
  reason      String?
  triggeredBy String   @map("triggered_by") // system or moderator userId
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([action])
  @@index([createdAt])
  @@map("review_moderation_logs")
}

// ============================================
// 场景相关
// ============================================

model Scene {
  id          String     @id @default(uuid())
  code        SceneCode  @unique
  name        String
  description String?
  icon        String?
  color       String?
  isActive    Boolean    @default(true) @map("is_active")
  config      Json?      // 场景专属配置
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  agentProfiles AgentProfile[]
  chatRooms     ChatRoom[]

  @@map("scenes")
}

enum SceneCode {
  VISION_SHARE  @map("vision_share")
  AGENT_DATE    @map("agent_date")
  AGENT_JOB     @map("agent_job")
  AGENT_AD      @map("agent_ad")
}

// ============================================
// Agent 画像相关
// ============================================

model AgentProfile {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  sceneId   String   @map("scene_id")

  // L1 - 基础信息（系统可查询）
  l1Data    Json     @map("l1_data")  // location, timeRange, category, budget

  // L2 - 结构化信息（Agent可读的自然语言）
  l2Data    Json     @map("l2_data")  // description, requirements, capabilities

  // L3 - 自然语言描述（完整描述）
  l3Description String? @map("l3_description")

  // 场景专属配置
  sceneConfig   Json?    @map("scene_config")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scene     Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([agentId, sceneId])
  @@index([agentId])
  @@index([sceneId])
  @@map("agent_profiles")
}

// ============================================
// 聊天室相关（四人群聊）
// ============================================

model ChatRoom {
  id            String        @id @default(uuid())
  sceneId       String?       @map("scene_id")
  matchId       String?       @unique @map("match_id")
  type          ChatRoomType  @default(QUAD)
  status        ChatRoomStatus @default(ACTIVE)
  participantIds String[]     @map("participant_ids")  // 存储 userIds
  metadata      Json?
  lastMessageAt DateTime?     @map("last_message_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  scene         Scene?        @relation(fields: [sceneId], references: [id])
  messages      ChatMessage[]
  connections   Connection[]
  participants  RoomParticipant[]

  @@index([sceneId])
  @@index([matchId])
  @@index([lastMessageAt])
  @@index([status])
  @@map("chat_rooms")
}

enum ChatRoomType {
  QUAD       @map("quad")       // 四人群聊（默认）
  PRIVATE    @map("private")    // 私聊
  GROUP      @map("group")      // 多人群聊
}

enum ChatRoomStatus {
  ACTIVE     @map("active")
  INACTIVE   @map("inactive")
  CLOSED     @map("closed")
}

model ChatMessage {
  id           String       @id @default(uuid())
  chatRoomId   String       @map("chat_room_id")
  senderId     String       @map("sender_id")
  senderType   SenderType   @map("sender_type")  // USER 或 AGENT
  content      String
  type         MessageType  @default(TEXT)
  status       MessageStatus @default(SENT)
  attachments  Json?
  metadata     Json?        // 包含私聊建议标记等
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  chatRoom     ChatRoom     @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

enum SenderType {
  USER   @map("user")
  AGENT  @map("agent")
}

// ============================================
// 连接管理（Socket/WebSocket）
// ============================================

model Connection {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  chatRoomId String?          @map("chat_room_id")
  socketId   String           @unique @map("socket_id")
  deviceInfo Json?            @map("device_info")
  ipAddress  String?          @map("ip_address")
  status     ConnectionStatus @default(ONLINE)
  lastPingAt DateTime?        @map("last_ping_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  // Relations
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatRoom   ChatRoom?        @relation(fields: [chatRoomId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([chatRoomId])
  @@index([status])
  @@index([lastPingAt])
  @@map("connections")
}

enum ConnectionStatus {
  ONLINE      @map("online")
  AWAY        @map("away")
  BUSY        @map("busy")
  OFFLINE     @map("offline")
}

// ============================================
// 信用和积分相关
// ============================================

model CreditRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  score       Int      // 当前信用分
  delta       Int      // 变化值
  reason      String   // 变化原因
  sourceType  String   @map("source_type")  // RATING, TRANSACTION, COMPLAINT 等
  sourceId    String?  @map("source_id")    // 关联记录ID
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_records")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  description String?
  referenceId String?         @map("reference_id")  // 关联订单/匹配ID
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

enum TransactionType {
  RECHARGE    @map("recharge")     // 充值
  REWARD      @map("reward")       // 奖励
  DEDUCT      @map("deduct")       // 扣除
  REFUND      @map("refund")       // 退款
  TRANSFER    @map("transfer")     // 转账
}

enum TransactionStatus {
  PENDING     @map("pending")
  SUCCESS     @map("success")
  FAILED      @map("failed")
  CANCELLED   @map("cancelled")
}

// ============================================
// 积分系统
// ============================================

model PointsAccount {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  balance       Int      @default(0)
  totalEarned   Int      @default(0) @map("total_earned")
  totalSpent    Int      @default(0) @map("total_spent")
  frozenAmount  Int      @default(0) @map("frozen_amount")
  version       Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  PointsTransaction[]
  freezes       PointsFreeze[]

  @@index([userId])
  @@map("points_accounts")
}

model PointsTransaction {
  id            String                @id @default(uuid())
  accountId     String                @map("account_id")
  userId        String                @map("user_id")
  type          PointsTransactionType
  amount        Int
  balanceAfter  Int                   @map("balance_after")
  description   String?
  scene         SceneCode?
  referenceId   String?               @map("reference_id")
  metadata      String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")

  // Relations
  account       PointsAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([userId])
  @@index([type])
  @@index([scene])
  @@index([createdAt])
  @@map("points_transactions")
}

model PointsFreeze {
  id            String       @id @default(uuid())
  accountId     String       @map("account_id")
  amount        Int
  reason        String
  scene         SceneCode?
  referenceId   String?      @map("reference_id")
  status        FreezeStatus @default(FROZEN)
  expiresAt     DateTime?    @map("expires_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations
  account       PointsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([status])
  @@index([expiresAt])
  @@map("points_freezes")
}

enum PointsTransactionType {
  EARN        @map("earn")
  SPEND       @map("spend")
  FROZEN      @map("frozen")
  UNFROZEN    @map("unfrozen")
  TRANSFER_IN @map("transfer_in")
  TRANSFER_OUT @map("transfer_out")
}

enum FreezeStatus {
  FROZEN      @map("frozen")      // 冻结中
  USED        @map("used")         // 已使用（完成交易）
  RELEASED    @map("released")     // 已释放（取消交易）
  EXPIRED     @map("expired")      // 已过期
}

// ============================================
// 用户设备管理
// ============================================

model UserDevice {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  deviceId    String    @unique @map("device_id")
  deviceName  String?   @map("device_name")
  deviceType  String?   @map("device_type") // ios, android, web
  osVersion   String?   @map("os_version")
  appVersion  String?   @map("app_version")
  pushToken   String?   @map("push_token")
  ipAddress   String?   @map("ip_address")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  isCurrent   Boolean  @default(false) @map("is_current")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@map("user_devices")
}

// ============================================
// 阻止列表
// ============================================

model BlockedUser {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  blockedUserId String @map("blocked_user_id")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation("BlockingUser", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser User     @relation("BlockedByUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([userId])
  @@index([blockedUserId])
  @@map("blocked_users")
}

// ============================================
// RBAC 权限系统
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique  // user, admin, moderator
  displayName String   @map("display_name")  // 显示名称
  description String?  // 角色描述
  level       Int      @default(0)  // 角色层级，用于继承
  isSystem    Boolean  @default(false) @map("is_system")  // 系统角色不可删除
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  permissions RolePermission[]
  users       UserRole[]

  @@index([name])
  @@index([level])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String   // 资源，如 users, agents, posts
  action      String   // 操作，如 read, write, delete, admin
  name        String   @unique  // users:read, users:write
  description String?  // 权限描述
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  roles       RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@index([action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  grantedBy String?  @map("granted_by")  // 谁授予的角色
  expiresAt DateTime? @map("expires_at")  // 角色过期时间（可选）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================
// 商家优惠相关 (Merchant & Offer)
// ============================================

model Merchant {
  id          String    @id @default(uuid())
  agentId     String    @unique @map("agent_id")
  name        String    // 店名
  address     String?   // 门店地址
  phone       String?   // 联系电话
  businessHours Json?   @map("business_hours") // 营业时间
  description String?   // 商家描述
  logoUrl     String?   @map("logo_url") // 商家logo
  category    String?   // 经营类目
  status      MerchantStatus @default(ACTIVE)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  offers      Offer[]
  coupons     Coupon[]

  @@index([agentId])
  @@index([status])
  @@map("merchants")
}

enum MerchantStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
  SUSPENDED @map("suspended")
}

model Offer {
  id          String    @id @default(uuid())
  merchantId  String    @map("merchant_id")
  title       String    // 优惠标题
  description String?   // 详细描述
  type        OfferType // 优惠类型

  // 优惠力度
  discountValue     Decimal?  @map("discount_value") @db.Decimal(5, 2) // 折扣值或减免金额
  minPurchaseAmount Decimal?  @map("min_purchase_amount") @db.Decimal(10, 2) // 最低消费金额
  maxDiscountAmount Decimal?  @map("max_discount_amount") @db.Decimal(10, 2) // 最高减免金额

  // 适用范围
  applicableScope   Json?     @map("applicable_scope") // {products: [], excludedProducts: [], timeRanges: [], storeIds: [], userGroups: []}

  // 有效期
  validFrom   DateTime  @map("valid_from")
  validUntil  DateTime  @map("valid_until")

  // 库存管理
  totalStock  Int       @map("total_stock") // 总库存数量
  dailyLimit  Int?      @map("daily_limit") // 每日限额
  remainingStock Int    @default(0) @map("remaining_stock") // 剩余库存
  stockAlertThreshold Int @default(10) @map("stock_alert_threshold") // 库存预警阈值

  // 状态管理
  status      OfferStatus @default(DRAFT)
  publishType OfferPublishType @default(MANUAL) @map("publish_type") // 发布类型
  scheduledPublishAt DateTime? @map("scheduled_publish_at") // 定时发布时间

  // AI提取相关
  aiExtracted       Boolean   @default(false) @map("ai_extracted") // 是否AI提取
  aiExtractionData  Json?     @map("ai_extraction_data") // AI提取的原始数据
  aiConfidence      Float?    @map("ai_confidence") // AI提取置信度

  // 统计
  usageCount  Int       @default(0) @map("usage_count") // 使用次数
  viewCount   Int       @default(0) @map("view_count") // 浏览次数

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  coupons     Coupon[]

  @@index([merchantId])
  @@index([status])
  @@index([type])
  @@index([validFrom, validUntil])
  @@index([aiExtracted])
  @@map("offers")
}

enum OfferType {
  DISCOUNT      @map("discount")      // 折扣 (如8折)
  REDUCTION     @map("reduction")     // 满减 (如满100减20)
  GIFT          @map("gift")          // 赠品
  PACKAGE       @map("package")       // 套餐
  PERCENTAGE    @map("percentage")    // 百分比折扣
  FIXED_AMOUNT  @map("fixed_amount")  // 固定金额优惠
}

enum OfferStatus {
  DRAFT       @map("draft")       // 草稿
  PENDING     @map("pending")      // 待审核
  ACTIVE      @map("active")       // 生效中
  PAUSED      @map("paused")       // 暂停
  EXPIRED     @map("expired")      // 已过期
  SOLD_OUT    @map("sold_out")     // 已售罄
  DISABLED    @map("disabled")     // 已下架
}

enum OfferPublishType {
  MANUAL      @map("manual")       // 手动发布
  SCHEDULED   @map("scheduled")    // 定时发布
  IMMEDIATE   @map("immediate")    // 立即发布
}

model SavedFilter {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String   // 筛选器名称
  description String?  // 筛选器描述
  category    String?  // 分类
  filter      Json     // FilterDSL JSON
  isPublic    Boolean  @default(false) @map("is_public")  // 是否公开
  usageCount  Int      @default(0) @map("usage_count")     // 使用次数
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([isPublic, usageCount])
  @@map("saved_filters")
}

// ============================================
// 场景模板
// ============================================

model SceneTemplate {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")  // null for preset templates
  sceneId     String   @map("scene_id") // visionshare, agentdate, agentjob, agentad
  name        String   // 模板名称
  description String?  // 模板描述
  isPreset    Boolean  @default(false) @map("is_preset")  // 是否是预设模板
  isDefault   Boolean  @default(false) @map("is_default") // 是否用户默认模板
  fieldValues Json     // 字段默认值
  isPublic    Boolean  @default(false) @map("is_public")  // 是否公开
  usageCount  Int      @default(0) @map("usage_count")    // 使用次数
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sceneId])
  @@index([isPublic, usageCount])
  @@index([userId, sceneId, isDefault])
  @@map("scene_templates")
}

// ============================================
// 通知系统相关 (Notification System)
// ============================================

// 通知记录
model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType // 通知类型
  title       String           // 通知标题
  content     String           // 通知内容
  data        Json?            // 额外数据（如matchId等）
  imageUrl    String?          @map("image_url") // 通知图片
  actionUrl   String?          @map("action_url") // 点击跳转URL
  category    String?          // 通知分类
  priority    PriorityLevel    @default(NORMAL) // 优先级
  channel     NotificationChannel @default(IN_APP) // 推送渠道
  status      NotificationStatus @default(UNREAD) // 状态
  sentAt      DateTime?        @map("sent_at")   // 发送时间
  readAt      DateTime?        @map("read_at")   // 已读时间
  expiresAt   DateTime?        @map("expires_at") // 过期时间
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  // Relations
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  NotificationDelivery[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, createdAt])
  @@index([type])
  @@index([status])
  @@map("notifications")
}

enum NotificationType {
  MATCH_NEW           @map("match_new")           // 新匹配
  MATCH_ACCEPTED      @map("match_accepted")      // 匹配被接受
  MATCH_REJECTED      @map("match_rejected")      // 匹配被拒绝
  MATCH_COMPLETED     @map("match_completed")     // 匹配完成
  MESSAGE_NEW         @map("message_new")         // 新消息
  RATING_RECEIVED     @map("rating_received")     // 收到评分
  REVIEW_RATING       @map("review_rating")       // 收到评价
  REVIEW_REMINDER     @map("review_reminder")     // 评价提醒
  SYSTEM_ANNOUNCEMENT @map("system_announcement") // 系统公告
  PROMOTION           @map("promotion")           // 促销活动
  REMINDER            @map("reminder")            // 提醒
}

enum NotificationChannel {
  IN_APP  @map("in_app")   // 应用内
  PUSH    @map("push")     // 推送
  EMAIL   @map("email")    // 邮件
  SMS     @map("sms")      // 短信
}

enum NotificationStatus {
  UNREAD    @map("unread")
  READ      @map("read")
  ARCHIVED  @map("archived")
  DELETED   @map("deleted")
}

enum PriorityLevel {
  LOW       @map("low")
  NORMAL    @map("normal")
  HIGH      @map("high")
  URGENT    @map("urgent")
}

// 通知投递记录
model NotificationDelivery {
  id              String    @id @default(uuid())
  notificationId  String    @map("notification_id")
  channel         NotificationChannel // 投递渠道
  status          DeliveryStatus @default(PENDING) // 投递状态
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  failedAt        DateTime? @map("failed_at")
  errorMessage    String?   @map("error_message")
  retryCount      Int       @default(0) @map("retry_count")
  externalId      String?   @map("external_id") // 外部服务ID（如Expo push receipt）
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([channel, status])
  @@index([status, retryCount])
  @@map("notification_deliveries")
}

enum DeliveryStatus {
  PENDING     @map("pending")
  SENT        @map("sent")
  DELIVERED   @map("delivered")
  FAILED      @map("failed")
  RETRYING    @map("retrying")
}

// 用户通知偏好设置
model NotificationPreference {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  // 推送开关
  pushEnabled       Boolean   @default(true) @map("push_enabled")
  emailEnabled      Boolean   @default(true) @map("email_enabled")
  smsEnabled        Boolean   @default(false) @map("sms_enabled")
  inAppEnabled      Boolean   @default(true) @map("in_app_enabled")
  // 通知类型偏好
  matchNotifications    Boolean @default(true) @map("match_notifications")
  messageNotifications  Boolean @default(true) @map("message_notifications")
  ratingNotifications   Boolean @default(true) @map("rating_notifications")
  systemNotifications   Boolean @default(true) @map("system_notifications")
  promotionNotifications Boolean @default(false) @map("promotion_notifications")
  // 频率控制
  dailyLimit        Int       @default(100) @map("daily_limit") // 每日通知上限
  quietHoursStart   String?   @map("quiet_hours_start") // 免打扰开始时间 (HH:mm)
  quietHoursEnd     String?   @map("quiet_hours_end")   // 免打扰结束时间 (HH:mm)
  quietHoursEnabled Boolean   @default(false) @map("quiet_hours_enabled")
  // 元数据
  updatedAt         DateTime  @updatedAt @map("updated_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_preferences")
}

// 推送令牌管理 (Expo Push Token)
model PushToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  token       String    @unique // Expo Push Token
  deviceId    String?   @map("device_id") // 设备ID
  deviceType  String    @map("device_type") // ios, android
  appVersion  String?   @map("app_version")
  osVersion   String?   @map("os_version")
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime  @default(now()) @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([userId, isActive])
  @@map("push_tokens")
}

// 邮件队列
model EmailQueue {
  id          String    @id @default(uuid())
  toEmail     String    @map("to_email")
  toName      String?   @map("to_name")
  templateId  String    @map("template_id") // 模板ID
  subject     String    // 邮件主题
  content     String?   // 邮件内容（HTML）
  variables   Json?     // 模板变量
  status      EmailStatus @default(PENDING)
  priority    Int       @default(0) // 优先级
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  openedAt    DateTime? @map("opened_at")
  clickedAt   DateTime? @map("clicked_at")
  errorMessage String?  @map("error_message")
  retryCount  Int       @default(0) @map("retry_count")
  messageId   String?   @map("message_id") // 邮件服务商返回的ID
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status, priority])
  @@index([toEmail])
  @@index([createdAt])
  @@map("email_queue")
}

enum EmailStatus {
  PENDING   @map("pending")
  SENDING   @map("sending")
  SENT      @map("sent")
  DELIVERED @map("delivered")
  OPENED    @map("opened")
  CLICKED   @map("clicked")
  BOUNCED   @map("bounced")
  FAILED    @map("failed")
}

// 短信队列
model SMSQueue {
  id          String    @id @default(uuid())
  phoneNumber String    @map("phone_number")
  templateId  String    @map("template_id")
  content     String    // 短信内容
  variables   Json?     // 模板变量
  status      SMSStatus @default(PENDING)
  priority    Int       @default(0)
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  errorMessage String?  @map("error_message")
  retryCount  Int       @default(0) @map("retry_count")
  messageId   String?   @map("message_id") // 短信服务商返回的ID
  segments    Int       @default(1) // 短信分段数
  cost        Decimal?  @db.Decimal(10, 4) // 短信成本
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status, priority])
  @@index([phoneNumber])
  @@index([createdAt])
  @@map("sms_queue")
}

enum SMSStatus {
  PENDING   @map("pending")
  SENDING   @map("sending")
  SENT      @map("sent")
  DELIVERED @map("delivered")
  FAILED    @map("failed")
}

enum CouponStatus {
  ACTIVE      @map("active")
  INACTIVE    @map("inactive")
  EXPIRED     @map("expired")
  USED        @map("used")
  REMINDER_SENT @map("reminder_sent")
  CANCELLED   @map("cancelled")
}

// ============================================
// 刷新令牌 (Refresh Token)
// ============================================

enum ParticipantRole {
  OWNER     @map("owner")
  ADMIN     @map("admin")
  MEMBER    @map("member")
  GUEST     @map("guest")
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String    @map("user_id")
  deviceInfo  Json?     @map("device_info")
  ipAddress   String?   @map("ip_address")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  revokedBy   String?   @map("revoked_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// 聊天室参与者 (Room Participant)
// ============================================

model RoomParticipant {
  id          String         @id @default(uuid())
  roomId      String         @map("room_id")
  userId      String         @map("user_id")
  role        ParticipantRole @default(MEMBER)
  permissions Json?          // 参与者权限配置
  isActive    Boolean        @default(true) @map("is_active")
  joinedAt    DateTime       @default(now()) @map("joined_at")
  addedBy     String?        @map("added_by")
  lastActiveAt DateTime?     @map("last_active_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  room        ChatRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("room_participants")
}

// ============================================
// 信用分历史 (Credit History)
// ============================================

model CreditHistory {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  score       Int      // 当前信用分
  delta       Int      // 变化值
  reason      String   // 变化原因
  sourceType  String   @map("source_type")
  sourceId    String? @map("source_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_history")
}

// ============================================
// 信用分快照 (Credit Score)
// ============================================

model CreditScore {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  score       Int      @default(75)
  level       String   @default("GENERAL")
  lastUpdated DateTime @default(now()) @map("last_updated")
  updatedBy   String?  @map("updated_by")
  reason      String?  // 更新原因
  nextUpdateAt DateTime? @map("next_update_at")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_scores")
}

// ============================================
// 地理位置围栏 (Geo-Fence)
// ============================================

model GeoFence {
  id           String   @id @default(uuid())
  name         String
  description  String?
  type         String   @default("POLYGON") // POLYGON, CIRCLE, RECTANGLE
  coordinates  Json?    // GeoJSON Polygon coordinates
  centerLat    Float?   @map("center_lat")
  centerLng    Float?   @map("center_lng")
  radiusMeters Float?   @map("radius_meters")
  color        String?
  createdBy    String?  @map("created_by")
  isActive     Boolean  @default(true) @map("is_active")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([createdBy])
  @@map("geo_fences")
}

// ============================================
// OAuth 连接 (OAuth Connection)
// ============================================

model OAuthConnection {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  provider         String    // google, apple, wechat, etc.
  providerUserId   String    @map("provider_user_id")
  accessToken      String?   @map("access_token")
  refreshToken     String?   @map("refresh_token")
  expiresAt        DateTime? @map("expires_at")
  scope            String?
  metadata         Json?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider])
  @@map("oauth_connections")
}

// ============================================
// VisionShare 任务 (VisionShare Task)
// ============================================

model VisionShareTask {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  title                String
  description           String?
  budgetType            String?   @map("budget_type")
  budgetAmount          Float?    @map("budget_amount")
  budgetCurrency        String?   @map("budget_currency")
  latitude              Float?
  longitude             Float?
  locationName          String?   @map("location_name")
  locationAddress       String?   @map("location_address")
  startTime             DateTime? @map("start_time")
  endTime               DateTime? @map("end_time")
  timeType              String?   @map("time_type")
  validHours            Int       @default(24) @map("valid_hours")
  expiresAt             DateTime  @map("expires_at")
  category              String?
  tags                  String[]  @default([])
  aiGeneratedTags       String[]  @default([]) @map("ai_generated_tags")
  aiRefinedDescription  String?   @map("ai_refined_description")
  qualityScore          Float?    @map("quality_score")
  status                String    @default("DRAFT")
  creditChecked         Boolean   @default(false) @map("credit_checked")
  contentFiltered       Boolean   @default(false) @map("content_filtered")
  viewCount             Int       @default(0) @map("view_count")
  matchCount            Int       @default(0) @map("match_count")
  shareCount            Int       @default(0) @map("share_count")
  publishCount          Int       @default(0) @map("publish_count")
  dailyLimitHit         Boolean   @default(false) @map("daily_limit_hit")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Relations
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("vision_share_tasks")
}

// VisionShare Task History
model VisionShareTaskHistory {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  status    String
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([taskId])
  @@map("vision_share_task_history")
}

// ============================================
// 优惠券 (Coupon) & 优惠券交易
// ============================================

model Coupon {
  id              String    @id @default(uuid())
  code            String    @unique
  name            String
  description     String?
  offerId         String?   @map("offer_id")
  merchantId      String?   @map("merchant_id")
  consumerId      String?   @map("consumer_id")
  originalPrice   Float?    @map("original_price")
  discountPrice   Float?    @map("discount_price")
  discountType     String    @map("discount_type") // PERCENTAGE, FIXED_AMOUNT
  discountValue    Float     @map("discount_value")
  minOrderAmount   Float?    @map("min_order_amount")
  maxDiscountAmount Float?   @map("max_discount_amount")
  validFrom       DateTime  @map("valid_from")
  validUntil      DateTime  @map("valid_until")
  totalCount      Int       @default(0) @map("total_count")
  remainingCount  Int       @default(0) @map("remaining_count")
  perUserLimit    Int       @default(1) @map("per_user_limit")
  usedCount       Int       @default(0) @map("used_count")
  maxUsageCount   Int       @default(1) @map("max_usage_count")
  usedAt          DateTime? @map("used_at")
  reminderSent    Boolean   @default(false) @map("reminder_sent")
  status          CouponStatus @default(ACTIVE)
  redeemedBy      String?   @map("redeemed_by")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  transactions    CouponTransaction[]
  ratings         CouponRating[]
  offer           Offer?    @relation(fields: [offerId], references: [id])
  merchant        Merchant? @relation(fields: [merchantId], references: [id])

  @@index([code])
  @@index([status])
  @@index([merchantId])
  @@index([consumerId])
  @@map("coupons")
}

model CouponTransaction {
  id          String   @id @default(uuid())
  couponId    String   @map("coupon_id")
  userId      String   @map("user_id")
  type        String   // ISSUE, USE, EXPIRE, CANCEL
  amount      Float?
  orderId     String?  @map("order_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@map("coupon_transactions")
}

model CouponRating {
  id          String   @id @default(uuid())
  couponId    String   @map("coupon_id")
  userId      String   @map("user_id")
  rating      Int      // 1-5
  comment     String?
  isUseful    Boolean  @default(false) @map("is_useful")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_ratings")
}

// ============================================
// 离线消息 (Offline Message)
// ============================================

model OfflineMessage {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  messageId       String    @map("message_id")
  conversationId  String    @map("conversation_id")
  deliveredAt     DateTime? @map("delivered_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deliveredAt])
  @@map("offline_messages")
}

// ============================================
// Agent Location Privacy Settings
// ============================================

model AgentLocationPrivacy {
  id              String   @id @default(uuid())
  agentId         String   @unique @map("agent_id")
  showExactCoords  Boolean @default(true) @map("show_exact_coords")
  hideFromPublic  Boolean @default(false) @map("hide_from_public")
  maxDistanceKm    Int     @default(50) @map("max_distance_km")
  privacyLevel    String?  @map("privacy_level")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@map("agent_location_privacy")
}
