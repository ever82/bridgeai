// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户相关
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  avatarUrl     String?   @map("avatar_url")
  phone         String?
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  agents        Agent[]
  sentMessages  Message[] @relation("SentMessages")
  ratingsGiven  Rating[]  @relation("Rater")
  ratingsReceived Rating[] @relation("Ratee")
  creditRecords CreditRecord[]
  transactions  Transaction[]
  connections   Connection[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// Agent 相关
// ============================================

model Agent {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  type        AgentType
  name        String
  config      Json?
  latitude    Float?
  longitude   Float?
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  demands     Demand[]
  supplies    Supply[]
  profiles    AgentProfile[]

  @@index([userId])
  @@index([type])
  @@index([latitude, longitude])
  @@map("agents")
}

enum AgentType {
  DEMAND
  SUPPLY
}

// ============================================
// 需求相关
// ============================================

model Demand {
  id          String       @id @default(uuid())
  agentId     String       @map("agent_id")
  title       String
  description String?
  tags        String[]
  budgetMin   Decimal?     @map("budget_min") @db.Decimal(10, 2)
  budgetMax   Decimal?     @map("budget_max") @db.Decimal(10, 2)
  latitude    Float?
  longitude   Float?
  status      DemandStatus @default(OPEN)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  matches     Match[]

  @@index([agentId])
  @@index([status])
  @@index([tags])
  @@map("demands")
}

enum DemandStatus {
  OPEN
  MATCHED
  CLOSED
}

// ============================================
// 供给相关
// ============================================

model Supply {
  id          String        @id @default(uuid())
  agentId     String        @map("agent_id")
  title       String
  description String?
  skills      String[]
  hourlyRate  Decimal?      @map("hourly_rate") @db.Decimal(10, 2)
  latitude    Float?
  longitude   Float?
  availability Json?
  status      SupplyStatus  @default(AVAILABLE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  agent       Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  matches     Match[]

  @@index([agentId])
  @@index([status])
  @@index([skills])
  @@map("supplies")
}

enum SupplyStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

// ============================================
// 匹配相关
// ============================================

model Match {
  id          String      @id @default(uuid())
  demandId    String      @map("demand_id")
  supplyId    String      @map("supply_id")
  score       Decimal     @db.Decimal(5, 2)
  status      MatchStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  demand      Demand      @relation(fields: [demandId], references: [id], onDelete: Cascade)
  supply      Supply      @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  conversation Conversation?
  ratings     Rating[]

  @@unique([demandId, supplyId])
  @@index([demandId])
  @@index([supplyId])
  @@index([status])
  @@map("matches")
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

// ============================================
// 会话和消息
// ============================================

model Conversation {
  id            String    @id @default(uuid())
  matchId       String    @unique @map("match_id")
  participantIds String[]  @map("participant_ids")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([matchId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String        @id @default(uuid())
  conversationId  String        @map("conversation_id")
  senderId        String        @map("sender_id")
  content         String
  type            MessageType   @default(TEXT)
  attachments     Json?
  createdAt       DateTime      @default(now()) @map("created_at")

  // Relations
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User          @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

// ============================================
// 评分相关
// ============================================

model Rating {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  raterId   String   @map("rater_id")
  rateeId   String   @map("ratee_id")
  score     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  rater     User     @relation("Rater", fields: [raterId], references: [id])
  ratee     User     @relation("Ratee", fields: [rateeId], references: [id])

  @@index([matchId])
  @@index([rateeId])
  @@map("ratings")
}

// ============================================
// 场景相关
// ============================================

model Scene {
  id          String     @id @default(uuid())
  code        SceneCode  @unique
  name        String
  description String?
  icon        String?
  color       String?
  isActive    Boolean    @default(true) @map("is_active")
  config      Json?      // 场景专属配置
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  agentProfiles AgentProfile[]
  chatRooms     ChatRoom[]

  @@map("scenes")
}

enum SceneCode {
  VISION_SHARE  @map("vision_share")
  AGENT_DATE    @map("agent_date")
  AGENT_JOB     @map("agent_job")
  AGENT_AD      @map("agent_ad")
}

// ============================================
// Agent 画像相关
// ============================================

model AgentProfile {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  sceneId   String   @map("scene_id")

  // L1 - 基础信息（系统可查询）
  l1Data    Json     @map("l1_data")  // location, timeRange, category, budget

  // L2 - 结构化信息（Agent可读的自然语言）
  l2Data    Json     @map("l2_data")  // description, requirements, capabilities

  // L3 - 自然语言描述（完整描述）
  l3Description String? @map("l3_description")

  // 场景专属配置
  sceneConfig   Json?    @map("scene_config")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  scene     Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([agentId, sceneId])
  @@index([agentId])
  @@index([sceneId])
  @@map("agent_profiles")
}

// ============================================
// 聊天室相关（四人群聊）
// ============================================

model ChatRoom {
  id            String        @id @default(uuid())
  sceneId       String?       @map("scene_id")
  matchId       String?       @unique @map("match_id")
  type          ChatRoomType  @default(QUAD)
  status        ChatRoomStatus @default(ACTIVE)
  participantIds String[]     @map("participant_ids")  // 存储 userIds
  metadata      Json?
  lastMessageAt DateTime?     @map("last_message_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  scene         Scene?        @relation(fields: [sceneId], references: [id])
  messages      ChatMessage[]
  connections   Connection[]

  @@index([sceneId])
  @@index([matchId])
  @@index([lastMessageAt])
  @@index([status])
  @@map("chat_rooms")
}

enum ChatRoomType {
  QUAD       @map("quad")       // 四人群聊（默认）
  PRIVATE    @map("private")    // 私聊
  GROUP      @map("group")      // 多人群聊
}

enum ChatRoomStatus {
  ACTIVE     @map("active")
  INACTIVE   @map("inactive")
  CLOSED     @map("closed")
}

model ChatMessage {
  id           String       @id @default(uuid())
  chatRoomId   String       @map("chat_room_id")
  senderId     String       @map("sender_id")
  senderType   SenderType   @map("sender_type")  // USER 或 AGENT
  content      String
  type         MessageType  @default(TEXT)
  attachments  Json?
  metadata     Json?        // 包含私聊建议标记等
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  chatRoom     ChatRoom     @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

enum SenderType {
  USER   @map("user")
  AGENT  @map("agent")
}

// ============================================
// 连接管理（Socket/WebSocket）
// ============================================

model Connection {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  chatRoomId String?          @map("chat_room_id")
  socketId   String           @unique @map("socket_id")
  deviceInfo Json?            @map("device_info")
  ipAddress  String?          @map("ip_address")
  status     ConnectionStatus @default(ONLINE)
  lastPingAt DateTime?        @map("last_ping_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  // Relations
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatRoom   ChatRoom?        @relation(fields: [chatRoomId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([chatRoomId])
  @@index([status])
  @@index([lastPingAt])
  @@map("connections")
}

enum ConnectionStatus {
  ONLINE      @map("online")
  AWAY        @map("away")
  BUSY        @map("busy")
  OFFLINE     @map("offline")
}

// ============================================
// 信用和积分相关
// ============================================

model CreditRecord {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  score       Int      // 当前信用分
  delta       Int      // 变化值
  reason      String   // 变化原因
  sourceType  String   @map("source_type")  // RATING, TRANSACTION, COMPLAINT 等
  sourceId    String?  @map("source_id")    // 关联记录ID
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_records")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  description String?
  referenceId String?         @map("reference_id")  // 关联订单/匹配ID
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

enum TransactionType {
  RECHARGE    @map("recharge")     // 充值
  REWARD      @map("reward")       // 奖励
  DEDUCT      @map("deduct")       // 扣除
  REFUND      @map("refund")       // 退款
  TRANSFER    @map("transfer")     // 转账
}

enum TransactionStatus {
  PENDING     @map("pending")
  SUCCESS     @map("success")
  FAILED      @map("failed")
  CANCELLED   @map("cancelled")
}
