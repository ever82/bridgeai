{
  "name": "@bridgeai/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "BridgeAI 移动端 - Expo React Native",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo build",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:update": "jest --updateSnapshot",
    "e2e": "ts-node e2e/maestro/runner.ts --layer 2",
    "e2e:l0": "ts-node e2e/maestro/runner.ts --layer 0",
    "e2e:l2": "ts-node e2e/maestro/runner.ts --layer 2 --platform ios",
    "e2e:l2:dev": "ts-node e2e/maestro/runner.ts --layer 2 --platform ios --dev",
    "e2e:debug": "ts-node e2e/maestro/runner.ts --layer 2 --platform ios --dev --screenshot-on-failure",
    "e2e:ios": "ts-node e2e/maestro/runner.ts --layer 2 --platform ios",
    "e2e:android": "ts-node e2e/maestro/runner.ts --layer 2 --platform android",
    "e2e:install": "ts-node e2e/maestro/runner.ts --install",
    "test:e2e:ios": "detox test -c ios.sim.debug",
    "test:e2e:android": "detox test -c android.emu.debug",
    "test:e2e:build:ios": "detox build -c ios.sim.debug",
    "test:e2e:build:android": "detox build -c android.emu.debug",
    "clean": "rm -rf node_modules/.cache"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@bridgeai/shared": "workspace:*",
    "@expo/metro-runtime": "~3.1.3",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@sentry/react-native": "5.20.0",
    "axios": "^1.6.5",
    "expo": "~50.0.0",
    "expo-av": "~13.10.0",
    "expo-camera": "14.1.3",
    "expo-document-picker": "^55.0.13",
    "expo-image-picker": "~14.7.0",
    "expo-location": "~16.5.0",
    "expo-notifications": "~0.27.0",
    "expo-secure-store": "~12.8.0",
    "expo-status-bar": "~1.11.0",
    "nativewind": "^2.0.11",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-maps": "1.10.0",
    "react-native-reanimated": "~3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-web": "~0.19.13",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.11",
    "@types/react": "~18.2.45",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-expo": "~50.0.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "react-native-mock-render": "^0.1.9",
    "detox": "^20.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
