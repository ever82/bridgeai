{
  "name": "visionshare",
  "version": "0.1.0",
  "private": true,
  "description": "VisionShare - AI驱动的供需匹配平台",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter e2e test",
    "test:e2e:ui": "pnpm --filter e2e test:ui",
    "test:integration": "pnpm --filter e2e test:integration",
    "test:coverage": "node scripts/merge-coverage.js",
    "test:coverage:server": "pnpm --filter server test -- --coverage",
    "test:coverage:mobile": "pnpm --filter mobile test -- --coverage",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:seed": "pnpm --filter server db:seed"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "glob": "^13.0.6",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
