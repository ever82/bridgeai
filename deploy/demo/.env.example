# BridgeAI Demo Environment Configuration
# Copy this file to .env and customize for your demo setup

# Database
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bridgeai_demo
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO / Object Storage
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=bridgeai-demo
# Public endpoint for CDN/internet access
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Server
SERVER_PORT=3000

# Nginx
HTTP_PORT=80
HTTPS_PORT=443

# Security - CHANGE THESE IN PRODUCTION
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-me

# Monitoring
SENTRY_DSN=

# Demo mode
DEMO_MODE=true