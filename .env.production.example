# ============================================
# VisionShare 生产环境变量配置模板
# ============================================
# 复制此文件为 .env.production 并填入实际值

# ============================================
# 基础配置
# ============================================
NODE_ENV=production
PORT=3000
API_URL=https://api.visionshare.com
CLIENT_URL=https://visionshare.com

# ============================================
# 数据库配置 (PostgreSQL + PostGIS)
# ============================================
DATABASE_URL=postgresql://user:password@db.visionshare.com:5432/visionshare_prod

DB_HOST=db.visionshare.com
DB_PORT=5432
DB_NAME=visionshare_prod
DB_USER=visionshare
DB_PASSWORD=your_secure_password

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://redis.visionshare.com:6379
REDIS_DB_CACHE=0
REDIS_DB_SOCKET=1
REDIS_DB_QUEUE=2

# ============================================
# JWT 认证配置 (使用强密钥)
# ============================================
JWT_SECRET=your-production-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-production-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# AI 服务配置
# ============================================
ANTHROPIC_API_KEY=your-production-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-opus-20240229

OPENAI_API_KEY=your-production-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

AI_DEFAULT_MODEL=claude-3-opus-20240229
AI_FALLBACK_MODEL=claude-3-sonnet-20240229
AI_TIMEOUT_MS=300000
AI_MAX_RETRIES=3

# ============================================
# 对象存储配置 (AWS S3)
# ============================================
S3_ENDPOINT=s3.amazonaws.com
S3_PORT=443
S3_USE_SSL=true
S3_ACCESS_KEY=your-aws-access-key
S3_SECRET_KEY=your-aws-secret-key
S3_BUCKET_NAME=visionshare-prod
S3_PUBLIC_URL=https://visionshare-prod.s3.amazonaws.com

# ============================================
# 邮件服务配置
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# ============================================
# 推送通知配置 (Expo)
# ============================================
EXPO_ACCESS_TOKEN=your-expo-access-token

# ============================================
# 日志与监控
# ============================================
LOG_LEVEL=warn
LOG_PRETTY=false

# ============================================
# 安全配置
# ============================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=https://visionshare.com

# ============================================
# 功能开关
# ============================================
ENABLE_AI_FALLBACK=true
ENABLE_REQUEST_LOGGING=true
ENABLE_SWAGGER=false

# ============================================
# 移动端配置 (Expo)
# ============================================
EXPO_PUBLIC_API_URL=https://api.visionshare.com
EXPO_PUBLIC_WS_URL=wss://api.visionshare.com
